{
  "core_detection": {
    "blur_size": 7,
    "adaptive_block_size_ratio": 0.1,
    "adaptive_c": 7,
    "invert_threshold": 1,
    "morph_close_size": 15,
    "min_area": 2000,
    "max_area_ratio": 0.80,
    "epsilon": 0.02,
    "rectangularity_threshold": 0.80,
    "aspect_ratio_threshold": 2.0,
    "convexity_threshold": 0.95
  },
  "stability": {
    "smoothing_factor": 20,
    "subpixel_refinement": true,
    "depth_smoothing_factor": 10
  },
  "depth": {
    "min_depth": 0.1,       # Minimum valid depth (meters)
    "max_depth": 5.0,       # Maximum valid depth (meters)
    "depth_consistency_threshold": 0.05,  # Max allowed depth variance for a corner (meters)
    "use_depth_segmentation": true,
    "depth_segmentation_threshold": 0.5   # Depth threshold for segmentation (meters)
  },
  "camera": {
    "rgb_device_id": 0,
    "depth_device_id": 0,
    "width": 640,
    "height": 480,
    "fps": 30
  },
  "debug": {
    "show_debug": false,
    "show_3d": false,
    "save_results": false,
    "log_level": "INFO"
  }
}
